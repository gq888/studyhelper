# 火山方舟 API（doubao-seed-2.0-pro）
API_KEY=your-volcengine-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2.0-pro

# JWT
JWT_SECRET=please-change-me-in-production-very-long-random-string
JWT_EXPIRES_IN=30d

# Server
PORT=8787
NODE_ENV=development
CORS_ORIGIN=*

# DB
DATABASE_URL=file:./prisma/dev.db

# 第三方接口（按需购买后填入）
# 短信验证码（如阿里云、腾讯云）：SMS_*
# 真实支付（如 Stripe / 支付宝 / 微信支付）：PAY_*
# 对象存储（如阿里 OSS / 腾讯 COS / S3）：OSS_*
# 视频解析（抖音/B 站等第三方接口）：VIDEO_PARSE_*
